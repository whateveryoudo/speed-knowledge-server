# 复制为同目录 deploy.env 后按需修改（deploy.env 勿提交）
# cp scripts/deploy.env.example scripts/deploy.env

# 阿里云 ACR（与 docker-compose.example.yml 中 ACR_REGISTRY 一致）
ACR_REGISTRY=crpi-ewcecvhd15oyzexv.cn-chengdu.personal.cr.aliyuncs.com/speed-knowledge

# 镜像 tag，日常用 latest；发版可改为 v1.0.0 等
IMAGE_TAG=latest

# ECS 信息（--deploy 时用于 SSH 拉取并重建容器）
ECS_HOST=8.137.203.142
ECS_USER=root
ECS_PROJECT_DIR=/opt/speed-knowledge-server

# 构建平台（ECS 一般为 amd64）
PLATFORM=linux/amd64

# 可选：非交互登录 ACR（阿里云控制台 -> 容器镜像服务 -> 访问凭证 -> 固定密码）
# 不填则脚本会弹出 docker login 交互登录
# ACR_USERNAME=你的阿里云账号
# ACR_PASSWORD=
