# 应用配置
APP_NAME=FastAPI Server
ENVIRONMENT=production
API_V1_STR=/api/v1
DEBUG=False
PORT=8010
DOMAIN=8.137.203.142

# 数据库配置
DATABASE_URL=mysql+pymysql://root:change_me@db:3306/speed-knowledge
# jwt配置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
SECRET_KEY=change_me

# nodejs协同服务

NODEJS_SERVICE_URL=http://nestjs:3000
# 需和node端一致
INTERNAL_SERVICE_TOKEN=change_me


# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=True

# minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=speed-knowledge
MINIO_USE_SSL=False

# 阿里云Direct Mail配置
ALIYUN_DM_USE_ECS_RAM_ROLE=True
ALIYUN_DM_ACCESS_KEY_ID=Change_me
ALIYUN_DM_ACCESS_KEY_SECRET=Change_me
ALIYUN_DM_ACCOUNT_NAME=Change_me
ALIYUN_DM_FROM_ALIAS=SpeedDoc
ALIYUN_DM_REGISTER_SUBJECT=SpeedDoc 注册验证码
ALIYUN_DM_TEMPLATE_ID=Change_me
ALIYUN_DM_REGION=cn-hangzhou
EMAIL_CODE_EXPIRE_SECONDS=300
EMAIL_CODE_COOLDOWN_SECONDS=60


# 登录失败次数和窗口时间
LOGIN_FAIL_THRESHOLD=3
LOGIN_FAIL_WINDOW_SECONDS=60

# CORS 配置
CORS_ORIGINS_RAW=http://8.137.203.142,http://localhost:5173

# mq配置
RABBITMQ_URL=amqp://app:app_pass@rabbitmq:5672
RABBITMQ_ROUTING_KEY=document.content.updated
RABBITMQ_EXCHANGE=speed_knowledge.events

RABBITMQ_QUEUE=vector_sync.document_content_updated



# 重试
RABBITMQ_RETRY_QUEUE=vector_sync.document_content_updated.retry
# 死信
RABBITMQ_DLQ_QUEUE=vector_sync.document_content_updated.dlq

# 重试次数和间隔
RABBITMQ_MAX_RETRIES=5
RABBITMQ_RETRY_DELAY_MS=5000

# MQ 文档向量同步（需 Qdrant + embedding；生产先 false，云端向量调通后再开）
ENABLE_VECTOR_SYNC=false

# AI 路由（需 uv sync --group ai；生产 slim 镜像保持 false）
ENABLE_AI=false

# onlyoffice配置
ONLYOFFICE_JWT_SECRET=change_me
ONLYOFFICE_SERVER_URL=http://8.137.203.142:8080

# 火山引擎配置
VOLC_API_KEY="sk-your-api-key-here"
VOLC_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
# sdk自动填入了端点id
VOLC_MODEL=doubao-seed-1-8-251228

# ai机器人相关配置（预留（目前还没创建使用文档））
SYNC_VECTOR_KNOWLEDGE_ID=000000

QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=public_help_chunks_384

# 本地向量库
EMBED_MODEL_NAME=BAAI/bge-small-zh-v1.5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=8


LANGCHAIN_PROJECT=speed-knowledge-server
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=change_me


# 千问llmkey(请切换你自己的key)
DASHSCOPE_API_KEY='sk-your-api-key-here'
QWEN_MODEL=qwen-plus