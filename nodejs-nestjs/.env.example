# NestJS 本地 / env_file 打底配置
# 复制: cp .env.example .env
# 生产容器: compose 会用 environment 覆盖下方 localhost 主机名，并注入根 .env 的共享密钥

# 服务端口（本地可 3004；容器内由 compose 覆盖为 3000）
PORT=3004

# 数据库（本地连宿主机 MySQL；生产 DB_HOST/密码由 compose 覆盖）
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=change_me
DB_DATABASE=speed-knowledge

# JWT（生产请与根 .env 的 JWT_SECRET 保持一致，compose 会覆盖）
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=10080s

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# CORS
CORS_ORIGIN=*

# MinIO（生产 endpoint/密钥由 compose 覆盖为服务名 + 根 .env）
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=speed-knowledge
MINIO_USE_SSL=false

# RabbitMQ
RABBITMQ_URL=amqp://app:app_pass@localhost:5672
RABBITMQ_ROUTING_KEY=document.content.updated
RABBITMQ_EXCHANGE=speed_knowledge.events

# Python 主服务（生产由 compose 覆盖为 http://app:8010）
PYTHON_SERVER_URL=http://localhost:8010

PYTHON_PUBLIC_URL=change_me

# 与 Python / 根 .env 共用的内部调用令牌（生产 compose 覆盖）
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# 向量同步测试用知识库（可选）
SYNC_VECTOR_KNOWLEDGE_ID=
