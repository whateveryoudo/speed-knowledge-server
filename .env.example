# Compose 根配置：仅共享密钥 / 插值用（不会自动进容器，需被 compose ${} 或 env_file 引用）
# 复制: cp .env.example .env

# 阿里云 ACR
ACR_REGISTRY=Change_me

# MySQL（db 服务 + app/nestjs 注入）
MYSQL_ROOT_PASSWORD=Change_me
MYSQL_DATABASE=speed-knowledge

# 与 Python SECRET_KEY / Nest JWT_SECRET 对齐
JWT_SECRET=Change_me

# Python ↔ Nest 内部调用令牌（两边需一致）
INTERNAL_SERVICE_TOKEN=Change_me

# OnlyOffice（documentserver + python-fastapi）
ONLYOFFICE_JWT_SECRET=Change_me

# MinIO（minio 服务账号 + app/nestjs 访问密钥）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=speed-knowledge

# RabbitMQ
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=app_pass

# Python FastAPI 公网 URL
PYTHON_PUBLIC_URL=change_me
